# Forkable login (PRD §7.1 — captured `createSession` mutation)
FORKABLE_EMAIL=you@example.com
FORKABLE_PASSWORD=

# OpenAI (gpt-4o-mini for meal scoring)
OPENAI_API_KEY=

# Resend (failure email)
RESEND_API_KEY=
NOTIFY_TO_EMAIL=you@example.com
# NOTIFY_FROM_EMAIL — optional. Defaults to onboarding@resend.dev (Resend's
# universally-verified sender). Override only if you have a custom verified
# domain in Resend.
# NOTIFY_FROM_EMAIL=forkable-bot@yourdomain.com

# Per-request timeouts (milliseconds). Both default to sensible values
# (Forkable: 30s, Resend: 10s) and only need overriding if the upstream
# is unusually slow or you want to fail faster locally.
# FORKABLE_TIMEOUT_MS=30000
# RESEND_TIMEOUT_MS=10000

# Verbose logging — set to 1 to enable debug() output.
# DEBUG=1
