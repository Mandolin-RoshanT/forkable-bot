{
  "name": "forkable-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Weekly meal auto-picker for forkable.com — scores alternatives against a fat-loss rubric and swaps the highest-scoring meal.",
  "scripts": {
    "spike": "bun scripts/capture-ops.ts",
    "pick": "bun src/index.ts pick",
    "dry-run": "bun src/index.ts dry-run",
    "show-week": "bun src/index.ts show-week",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "codegen": "graphql-codegen --config codegen.ts",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.3.0",
    "@types/bun": "^1.2.0",
    "msw": "^2.6.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
